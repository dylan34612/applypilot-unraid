# Copy to .env and fill in (or paste into the Unraid Compose Manager env editor).

# WebUI port on the host (http://your-server:8484)
WEBUI_PORT=8484

# noVNC port — live view of the browser (http://your-server:8485/vnc.html)
NOVNC_PORT=8485

# Image tag to run. "latest" = main branch; set to a branch name
# (e.g. "upstream-prep") to test a PR build before it merges. The WebUI's
# Docker panel can also change this for you.
IMAGE_TAG=latest

# HOST path of the directory that holds THIS docker-compose.yml and .env.
# Required for the WebUI's Docker panel to pull updates and restart the stack.
# For a plain deployment this is wherever you put the files; for the Compose
# Manager plugin it's /boot/config/plugins/compose.manager/projects/<name>.
# Leave unset to disable the update button (everything else still works).
STACK_DIR=/mnt/user/appdata/applypilot-stack

# Throwaway image used to recreate this container during an update (a
# container can't cleanly restart itself). Any image with the compose plugin.
HELPER_IMAGE=docker:cli

# ---------------------------------------------------------------------------
# Your OpenAI-compatible endpoint — powers discovery enrichment, scoring,
# resume tailoring, and cover letters (stages 1-5). Natively supported.
# ---------------------------------------------------------------------------
LLM_URL=https://your-endpoint.example.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=your-model-name

# Alternative providers for stages 1-5 (optional). Only used if set;
# LLM_URL above takes precedence over both.
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Scraping proxy in host:port:user:pass format (optional). Passed through
# for parity with upstream — note the current ApplyPilot release doesn't
# read it yet.
# PROXY=

# ---------------------------------------------------------------------------
# Auto-apply (stage 6) — the Claude Code CLI drives the browser.
# Default: routed through the bundled LiteLLM bridge to YOUR endpoint.
# ---------------------------------------------------------------------------
BRIDGE_UPSTREAM_BASE=https://your-endpoint.example.com/v1
BRIDGE_UPSTREAM_KEY=sk-your-key
BRIDGE_UPSTREAM_MODEL=your-model-name

# Leave these as-is to use the bridge:
ANTHROPIC_BASE_URL=http://litellm:4000
ANTHROPIC_AUTH_TOKEN=bridge

# ...or comment out the two lines above and set this to use the real
# Anthropic API for auto-apply (better form-navigation reliability):
# ANTHROPIC_API_KEY=sk-ant-your-key
